# =============================================================================
# Product Service — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your local machine.
# NEVER commit .env to Git (it is listed in .gitignore).
# =============================================================================

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=product_db
DB_USERNAME=product_user
DB_PASSWORD=product_pass

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=product.events

# --- Docker Compose (used by docker-compose.yml) ---
POSTGRES_USER=product_user
POSTGRES_PASSWORD=product_pass
POSTGRES_DB=product_db
