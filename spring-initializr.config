# =============================================================================
# Spring Initializr Configuration — Product Service
# =============================================================================
# Web UI:  https://start.spring.io
# API URL: https://start.spring.io/starter.zip
#
# Use this file to regenerate the base project from Spring Initializr.
# After download, re-apply custom files (application-*.yml, docker-compose, etc.)
# =============================================================================

[project]
type             = maven-project
language         = java
bootVersion      = 3.5.3
groupId          = com.swst41062.ecommerce
artifactId       = product-service
name             = product-service
description      = Product microservice for e-commerce platform
packageName      = com.swst41062.ecommerce.product
packaging        = jar
javaVersion      = 21

[dependencies]
# Spring Web          — REST API, embedded Tomcat
web                 = org.springframework.boot:spring-boot-starter-web
# Spring Data JPA     — PostgreSQL persistence via Hibernate
data-jpa            = org.springframework.boot:spring-boot-starter-data-jpa
# Validation          — Bean Validation (@NotNull, @Size, etc.)
validation          = org.springframework.boot:spring-boot-starter-validation
# Spring for RabbitMQ — AMQP messaging
amqp                = org.springframework.boot:spring-boot-starter-amqp
# PostgreSQL Driver   — JDBC driver (runtime)
postgresql          = org.postgresql:postgresql
# Flyway Migration  — Versioned database schema
flyway              = org.flywaydb:flyway-core
# Spring Boot Actuator — Health checks (/actuator/health)
actuator            = org.springframework.boot:spring-boot-starter-actuator
# DevTools          — Hot reload during development
devtools            = org.springframework.boot:spring-boot-devtools

[dependencies.manual]
# Added manually after Initializr generation (not available as a single Initializr checkbox):
# springdoc-openapi-starter-webmvc-ui — Swagger UI + OpenAPI 3 documentation

[download.url]
full = https://start.spring.io/starter.zip?type=maven-project&language=java&bootVersion=3.5.3&groupId=com.swst41062.ecommerce&artifactId=product-service&name=product-service&description=Product%20microservice%20for%20e-commerce%20platform&packageName=com.swst41062.ecommerce.product&packaging=jar&javaVersion=21&dependencies=web,data-jpa,validation,amqp,postgresql,flyway,actuator,devtools
